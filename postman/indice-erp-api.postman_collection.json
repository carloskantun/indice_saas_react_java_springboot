              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.id) {",
                  "  pm.collectionVariables.set('employee_id', String(json.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
