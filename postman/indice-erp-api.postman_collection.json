            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Postman\",\n  \"last_name\": \"Employee\",\n  \"email\": \"postman.{{$timestamp}}@example.com\",\n  \"position\": \"Analyst\",\n  \"department\": \"Operations\",\n  \"salary\": \"5000.00\"\n}"
            },
