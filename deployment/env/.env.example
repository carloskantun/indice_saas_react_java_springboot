MYSQL_IMAGE=mysql:8.0
MYSQL_DATABASE=indice_db
MYSQL_USER=indice_user
MYSQL_PASSWORD=indice_pass
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_CHARACTER_SET=utf8mb4
MYSQL_COLLATION=utf8mb4_0900_ai_ci

MINIO_IMAGE=minio/minio:latest
MINIO_MC_IMAGE=minio/mc:latest
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_REGION=us-east-1
MINIO_BUCKET_ATTENDANCE=indice-hr-attendance
MINIO_BUCKET_BIOMETRIC=indice-hr-biometric
MINIO_PRESIGN_EXPIRY_SECONDS=900

WEB_HOST_PORT=8080
BACKEND_HOST_PORT=8082
MYSQL_HOST_PORT=3307
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
FACE_SERVICE_HOST_PORT=8091

WEB_PUBLIC_URL=http://localhost:8080
MINIO_PUBLIC_ENDPOINT=http://localhost:8080/storage
APP_WEB_ALLOWED_ORIGINS=http://localhost:8080
MINIO_CORS_ALLOWED_ORIGINS=http://localhost:8080
APP_SESSION_COOKIE_SECURE=false
APP_SESSION_COOKIE_SAME_SITE=lax
APP_SESSION_TIMEOUT=12h
SERVER_FORWARD_HEADERS_STRATEGY=framework
APP_HR_ATTENDANCE_ENFORCE_LOCATION_RADIUS=false
APP_HR_FACE_ENABLED=true
APP_HR_FACE_SESSION_EXPIRY_SECONDS=600

VITE_API_BASE_URL=
BACKEND_JAVA_OPTS=-Xms256m -Xmx768m
